<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.yolanda.daily-ai-briefing</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>/Users/yolanda/TraeProjects/AI/daily_ai_briefing.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/yolanda/TraeProjects/AI</string>

    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>9</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/yolanda/TraeProjects/AI/.briefing_cache/stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/yolanda/TraeProjects/AI/.briefing_cache/stderr.log</string>

    <key>RunAtLoad</key>
    <false/>

    <key>KeepAlive</key>
    <false/>
</dict>
</plist>
