# ============================================================
# AI产业+营销AI 每日新闻简报 — 配置文件
# 复制此文件为 .env 并填入你的真实 Key
# ============================================================

# DeepSeek API Key（必填）
# 注册地址：https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# PushPlus Token（推荐，微信推送排版精美）
# 注册地址：https://www.pushplus.plus → 微信扫码 → 获取 Token
PUSHPLUS_TOKEN=your_pushplus_token_here

# Server酱 SendKey（备选，仅 PushPlus 不可用时使用）
# 注册地址：https://sct.ftqq.com → 微信扫码 → 获取 SendKey
SERVERCHAN_SENDKEY=SCT123456your_sendkey_here

# NewsAPI Key（可选，增强新闻覆盖面）
# 注册地址：https://newsapi.org
NEWSAPI_KEY=